# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your personal chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase: Settings → Database → Connection string)
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection string (Upstash, Railway Redis, etc.)
REDIS_URL=

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Primary RPC endpoint — QuickNode or Helius recommended for speed
QUICKNODE_RPC_URL=
# Fallback RPC (optional but recommended)
SOLANA_BACKUP_RPC_URL=
# Generic alias — used if QUICKNODE_RPC_URL is not set
SOLANA_RPC_URL=

# ── Jupiter ───────────────────────────────────────────────────────────────────
# Leave blank to use the public Jupiter v6 endpoint (rate-limited on free tier)
# Set to your QuickNode Jupiter add-on URL for higher throughput
QUICKNODE_JUPITER_URL=

# ── Helius ────────────────────────────────────────────────────────────────────
# Required for on-chain pattern recognition (holder data, deployer history, etc.)
# Get a free key at helius.dev
HELIUS_API_KEY=

# ── Wallet ────────────────────────────────────────────────────────────────────
# Optional: pre-load a wallet via env instead of /settings
# Base58-encoded private key (same format as Phantom export)
WALLET_PRIVATE_KEY=
# Alias — only needed if WALLET_PRIVATE_KEY is not set
SOLANA_WALLET_PRIVATE_KEY=

# Optional: 64-char hex AES-256 key used to encrypt the wallet stored in the DB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If omitted, the key is derived from TELEGRAM_BOT_TOKEN (safe for single-user bots)
WALLET_ENCRYPTION_KEY=

# ── Deployment ────────────────────────────────────────────────────────────────
# Set automatically by Render or Railway — only needed for self-hosted deployments
# Must be the public HTTPS URL of this service (used for Telegram webhook registration)
RENDER_EXTERNAL_URL=
RAILWAY_STATIC_URL=

# ── Server ────────────────────────────────────────────────────────────────────
# Port the webhook server listens on (Render/Railway set this automatically)
PORT=10000
